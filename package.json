{
  "name": "exponavapp",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "landing": "npm run dev --prefix landing",
    "landing:build": "npm run build --prefix landing",
    "prebuild:android": "expo prebuild --platform android",
    "prebuild:ios": "expo prebuild --platform ios",
    "export:apk": "bash scripts/build-android-apk-local.sh",
    "export:ipa": "bash scripts/build-ios-ipa-local.sh",
    "export:ipa:adhoc": "IOS_EXPORT_METHOD=ad-hoc bash scripts/build-ios-ipa-local.sh",
    "export:ipa:testflight": "IOS_EXPORT_METHOD=app-store bash scripts/build-ios-ipa-local.sh"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-glass-effect": "~0.1.10",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
